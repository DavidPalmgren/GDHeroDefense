init
    // kill after xavius dies?
    doPeriodically(ISOLATION_PERIOD) cb ->
        // Create a temporary group of all units on the map
        let g = CreateGroup()
        g.enumUnitsInRect(bj_mapInitialPlayableArea)
        
        for u from g
            if u.hasAbility(ISOLATION_BUFF_ID) and not u.hasAbility(NIGHTMARE_BUFF_ID)
                ENUM_GROUP.enumUnitsInRange(u.getPos(), 300, null)
                if not ENUM_GROUP.size() > 1
                    print("print size is: " + ENUM_GROUP.size().toString())
                    u.damageTarget(u, ISOLATION_DAMAGE, false, false, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_MAGIC, WEAPON_TYPE_WHOKNOWS)
                //ENUM_GROUP.destr()

        // Clean up the group to prevent memory leaks
        doAfter(5.) -> 
            g.destr()