import BuffIds

import Nightmare


public constant ISOLATION_ID = compiletime(ABIL_ID_GEN.next())
public constant ISOLATION_BUFF_ID = compiletime(BUFF_ID_GEN.next())

constant real ISOLATION_RADIUS = 1800.
constant real ISOLATION_DAMAGE = 15.
constant real ISOLATION_PERIOD = 1.

@compiletime function generateBuff()
    new BuffDefinition(ISOLATION_BUFF_ID, 'Basl')
        ..setName(1, "Isolation")
        ..setTooltipNormal(1, "Isolation")
        ..setTooltipNormalExtended(1, "This unit is being isolated by the emerald nightmare, keep your friends close.")
        ..setIcon(Icons.bTNPossession)
        ..setEffect("")


@compiletime function generateAbility()
    new AbilityDefinitionTaurenChieftainEnduranceAura(ISOLATION_ID)
        ..setName("Isolation")
        ..setTooltipNormal(1, "Isolation")
        ..setTooltipNormalExtended(1, "Applies the Isolation debuff to all nearby enemies within " + ISOLATION_RADIUS.toInt().toString() + " range.")
        ..setIconNormal(Icons.bTNPossession)
        ..setAreaofEffect(1, ISOLATION_RADIUS)
        ..setBuffs(1, toRawCode(ISOLATION_BUFF_ID))
        ..setTargetsAllowed(1, "enemy,ground,air,organic")
        ..setAttackSpeedIncrease(1, 0.)
        ..setMovementSpeedIncrease(1, 0.)
        ..setButtonPositionNormalX(0)
        ..setButtonPositionNormalY(2)
        ..setHeroAbility(false)
        ..setItemAbility(false)



