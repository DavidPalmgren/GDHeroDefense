package XaviusMain

import UnitObjEditing
import ObjectIdGenerator
import Nightmare
import ObjectIds

public constant XAVIUS_ID = 'N004'  // single quotes for raw codes, not double quotes

@compiletime function setupXavius()
    new UnitDefinition(XAVIUS_ID, XAVIUS_ID)
        ..setNormalAbilities(commaList(NIGHTMARE_ID))
        ..setLevel(6)