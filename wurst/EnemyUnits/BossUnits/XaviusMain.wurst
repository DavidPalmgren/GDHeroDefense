package XaviusMain

import UnitObjEditing
import ObjectIdGenerator
import ObjectIds

import Nightmare
import Isolation
import CorruptedBlood


public constant XAVIUS_ID = 'N004'

let abc = new UnitDefinition(XAVIUS_ID, XAVIUS_ID)

@compiletime function setupXavius()
    new UnitDefinition(XAVIUS_ID, XAVIUS_ID)
        ..setNormalAbilities(commaList(CORRUPTED_BLOOD_ID))
        ..setLevel(6)
        ..setName("Xavius")